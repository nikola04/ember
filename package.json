{
    "name": "ember",
    "private": true,
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:gateway": "bun --filter @ember/gateway dev",
        "dev:web": "bun --filter @ember/web dev",
        "db:generate": "bun --filter @ember/db generate",
        "db:migrate": "bun --filter @ember/db migrate",
        "infra:up": "docker compose -f infra/docker-compose.yml up -d",
        "infra:down": "docker compose -f infra/docker-compose.yml down"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5"
    }
}
