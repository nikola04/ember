{
    "name": "ember",
    "private": true,
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:gateway": "bun --env-file=.env --filter @ember/gateway dev",
        "dev:web": "bun --env-file=.env --filter @ember/web dev",
        "db:generate": "bun --filter @ember/db generate",
        "db:migrate": "bun --env-file=.env --filter @ember/db migrate"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "prettier": "3.8.4",
        "typescript": "^5"
    }
}
