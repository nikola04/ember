{
    "name": "ember",
    "private": true,
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:gateway": "bun --env-file=.env --filter @ember/gateway dev",
        "dev:web": "bun --env-file=.env --filter @ember/web dev",
        "db:generate": "bun --filter @ember/db generate",
        "db:migrate": "bun --env-file=.env --filter @ember/db migrate",
        "typecheck": "tsc -b --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "bun run typecheck && bun run lint && bun run format:check"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@typescript-eslint/eslint-plugin": "^8.15.0",
        "@typescript-eslint/parser": "^8.15.0",
        "eslint": "^9.15.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-tailwindcss": "^4.0.3",
        "prettier": "3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.1",
        "typescript": "^5"
    }
}
