# --- Gateway ---
NODE_ENV=development
GATEWAY_PORT=3000

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ember
POSTGRES_PASSWORD=ember
POSTGRES_DB=ember
DATABASE_URL=postgres://ember:ember@localhost:5432/ember

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Limits ---
MAX_USER_SERVERS=100
